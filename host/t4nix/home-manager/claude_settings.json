{
  "cleanupPeriodDays": 90,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git show *)",
      "Bash(rtk git status)",
      "Bash(rtk git status *)",
      "Bash(rtk git diff)",
      "Bash(rtk git diff *)",
      "Bash(rtk git log)",
      "Bash(rtk git log *)",
      "Bash(rtk gain)",
      "Bash(rtk gain *)",
      "Bash(rtk proxy *)",
      "Bash(rtk --version)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(**/secrets/**)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "effortLevel": "medium",
  "theme": "dark-daltonized"
}
